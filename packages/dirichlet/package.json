{
  "name": "@forecast-manifesto/dirichlet",
  "version": "0.1.0",
  "description": "多ブランド市場構造：デリシュレー NBD（Goodhardt-Ehrenberg-Chatfield 1984）。ダブルジェパディ・購買重複の法則をコードで検証する。",
  "license": "Apache-2.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/start-x-work/forecast-manifesto.git",
    "directory": "packages/dirichlet"
  },
  "homepage": "https://github.com/start-x-work/forecast-manifesto",
  "keywords": [
    "dirichlet",
    "nbd-dirichlet",
    "double-jeopardy",
    "brand-choice",
    "marketing",
    "start-x"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@forecast-manifesto/solver": "^0.2.0"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
